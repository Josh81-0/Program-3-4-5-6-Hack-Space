<EditForm Model="Model" OnValidSubmit="Calculate">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label>Principal</label>
        <InputNumber @bind-Value="Model.Principal" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Annual Rate (decimal)</label>
        <InputNumber @bind-Value="Model.AnnualRate" class="form-control" step="0.001" />
    </div>
    <div class="mb-3">
        <label>Years</label>
        <InputNumber @bind-Value="Model.Years" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Calculate & Save</button>
</EditForm>

@code {
    [Parameter] public FutureValueModel Model { get; set; } = new();
    [Parameter] public EventCallback<FutureValueModel> OnCalculate { get; set; }

    private async Task Calculate()
    {
        await OnCalculate.InvokeAsync(Model);
    }
}
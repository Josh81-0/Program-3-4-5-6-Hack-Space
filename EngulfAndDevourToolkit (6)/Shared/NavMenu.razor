@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Engulf & Devour</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <!-- Public Links (shown when NOT logged in) -->
        <AuthorizeView>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/blog">
                        <span class="bi bi-journal-text" aria-hidden="true"></span> Blog
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/contact">
                        <span class="bi bi-envelope" aria-hidden="true"></span> Contact
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>

            <!-- Protected Links (shown when logged in) -->
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/future-value">
                        <span class="bi bi-calculator" aria-hidden="true"></span> Future Value
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/balance-sheet">
                        <span class="bi bi-table" aria-hidden="true"></span> Balance Sheet
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/reserve-study">
                        <span class="bi bi-list-check" aria-hidden="true"></span> Reserve Study
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/contact-submissions">
                        <span class="bi bi-inbox" aria-hidden="true"></span> Contact Submissions
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/logout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout (@context.User.Identity?.Name)
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>
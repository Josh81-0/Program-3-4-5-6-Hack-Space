@if (isVisible)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isAsset ? "Add/Edit Asset" : "Add/Edit Liability")</h5>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="currentItem" OnValidSubmit="Save">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText @bind-Value="currentItem.Name" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Amount</label>
                            <InputNumber @bind-Value="currentItem.Amount" class="form-control" step="0.01" />
                        </div>

                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary ms-2" @onclick="Close">Cancel</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private LineItem currentItem = new();
    private bool isVisible;
    private bool isAsset;

    [Parameter] public EventCallback<(LineItem, bool)> OnSave { get; set; }

    public async Task Show(LineItem item, bool isAsset)
    {
        currentItem = new LineItem { Name = item.Name, Amount = item.Amount };
        this.isAsset = isAsset;
        isVisible = true;
        StateHasChanged();
    }

    private async Task Save()
    {
        await OnSave.InvokeAsync((currentItem, isAsset));
        Close();
    }

    private void Close()
    {
        isVisible = false;
        StateHasChanged();
    }
}